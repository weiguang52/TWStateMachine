# 极端传感器数据报警消息
string sensor_type           # 传感器类型 (temperature, humidity, combined)
string alert_level           # 报警级别 (normal, warning, critical, danger)
string alert_type            # 报警类型 (high, low, out_of_range)
float64 current_value        # 当前值
float64 threshold_value      # 阈值
string description           # 描述信息
builtin_interfaces/Time timestamp  # 时间戳
bool is_active               # 是否为活跃报警
uint32 alert_id              # 报警ID（用于追踪）